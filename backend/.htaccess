# 디렉토리 목록 비공개
Options -Indexes

# .env 및 민감 파일 직접 접근 차단
<FilesMatch "^(\.env|\.env\..*|\.htaccess|\.user\.ini|composer\.json|composer\.lock|\.gitignore)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# 모든 API 요청을 index.php 로 라우팅
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /backend/

    # 실제 파일/디렉토리는 그대로 서빙
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # 나머지는 index.php 로 전달
    RewriteRule ^ index.php [QSA,L]
</IfModule>

